// eas build --platform android --profile production - релизная сборка
{
  "cli": {
    "version": ">= 19.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "credentialsSource": "local"
    }
  },
  "submit": {
    "production": {}
  }
}
